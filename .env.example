# ── Shared ──────────────────────────────────────────────
# Frontend origin (used by backend for CORS + WS origin checks)
FRONTEND_URL=http://localhost:3000

# Backend base URL (used by frontend server-side)
BACKEND_URL=http://localhost:8080

# ── Frontend only ────────────────────────────────────────
# Backend WebSocket URL (exposed to browser)
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080

# ── Backend only ─────────────────────────────────────────
PORT=8080
